# Files to include in the sdist beyond what setuptools picks up by default.
# pyproject.toml, README.md, LICENSE, src/**, and tests/** are already auto-
# included.

include CHANGELOG.md
include CONTRIBUTING.md
include CLAUDE.md

# Top-level dotfiles + workflows are useful for contributors who download the
# sdist and want to rebuild from source.
recursive-include .github *.yml
include .gitignore
